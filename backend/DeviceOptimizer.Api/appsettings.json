{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=deviceoptimizer.db"
  },
  "IdleSettings": {
    "IdleThresholdDays": 7
  },
  "SimulatedFleet": {
    "Enabled": false,
    "TickIntervalSeconds": 15,
    "DevicesPerTick": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}